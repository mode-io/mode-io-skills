{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modeio.ai/schemas/modeio-plugin-manifest-v1.json",
  "title": "ModeIO Plugin Manifest v1",
  "type": "object",
  "required": [
    "name",
    "version",
    "protocol_version",
    "transport",
    "hooks"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "protocol_version": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "transport": {
      "type": "string",
      "enum": [
        "stdio-jsonrpc"
      ]
    },
    "hooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "pre.request",
          "post.response",
          "post.stream.start",
          "post.stream.event",
          "post.stream.end"
        ]
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "can_patch": {
          "type": "boolean"
        },
        "can_block": {
          "type": "boolean"
        },
        "needs_network": {
          "type": "boolean"
        },
        "needs_raw_body": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "timeout_ms": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 1
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
