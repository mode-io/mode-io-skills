# Optional API endpoint overrides
ANONYMIZE_API_URL=https://safety-cf.modeio.ai/api/cf/anonymize
SAFETY_API_URL=https://safety-cf.modeio.ai/api/cf/safety

# Live middleware routing
MODEIO_GATEWAY_UPSTREAM_API_KEY=<set-your-upstream-api-key>
MODEIO_MIDDLEWARE_UPSTREAM_CHAT_URL=https://api.openai.com/v1/chat/completions
MODEIO_MIDDLEWARE_UPSTREAM_RESPONSES_URL=https://api.openai.com/v1/responses

# Optional local map storage override for modeio-redact
MODEIO_REDACT_MAP_DIR=~/.modeio/redact/maps/
